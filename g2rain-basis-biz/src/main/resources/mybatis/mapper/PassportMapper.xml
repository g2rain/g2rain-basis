<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.g2rain.basis.dao.PassportDao">
    <!-- 通用结果集映射（包含所有字段：主键+基础字段+业务字段） -->
    <resultMap id="BaseResultMap" type="com.g2rain.basis.dao.po.PassportPo">
        <!-- 主键字段 -->
        <id column="id" property="id" jdbcType="BIGINT"/>
        <!-- 基础字段（createTime、updateTime） -->
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
        <result column="update_time" property="updateTime" jdbcType="TIMESTAMP"/>
        <!-- 业务字段（其他自定义字段） -->
        <result column="username" property="username" jdbcType="VARCHAR"/>
        <result column="password" property="password" jdbcType="VARCHAR"/>
        <result column="real_name" property="realName" jdbcType="VARCHAR"/>
        <result column="sex" property="sex" jdbcType="VARCHAR"/>
        <result column="birthday" property="birthday" jdbcType="VARCHAR"/>
        <result column="id_no" property="idNo" jdbcType="VARCHAR"/>
        <result column="mobile" property="mobile" jdbcType="VARCHAR"/>
        <result column="email" property="email" jdbcType="VARCHAR"/>
        <result column="status" property="status" jdbcType="VARCHAR"/>
        <!-- deleteFlag字段（如果存在） -->
        <result column="delete_flag" property="deleteFlag" jdbcType="TINYINT"/>
        <!-- version字段（如果存在） -->
        <result column="version" property="version" jdbcType="INTEGER"/>
    </resultMap>

    <!-- 定义可复用排序方向片段 -->
    <sql id="directionClause">
        <choose>
            <when test="item.direction == 'DESC'">DESC</when>
            <otherwise>ASC</otherwise>
        </choose>
    </sql>

    <!-- 可复用的动态排序 SQL 片段 -->
    <sql id="dynamicOrderBy">
        <trim prefix="ORDER BY" suffixOverrides=",">
            <foreach collection="safeSorts" item="item" separator=",">
                <choose>
                    <when test="item.column == 'id'">
                        id
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'createTime'">
                        create_time
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'updateTime'">
                        update_time
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'username'">
                        username
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'password'">
                        password
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'realName'">
                        real_name
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'sex'">
                        sex
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'birthday'">
                        birthday
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'idNo'">
                        id_no
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'mobile'">
                        mobile
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'email'">
                        email
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'status'">
                        status
                        <include refid="directionClause"/>
                    </when>
                </choose>
            </foreach>
        </trim>
    </sql>

    <!-- 公共的查询条件 -->
    <sql id="commonWhereClause">
        <where>
            <!-- 主键筛选 -->
            <if test="id != null">
                AND id = #{id, jdbcType=BIGINT}
            </if>
            <if test="ids != null and ids.size() > 0">
                AND id IN
                <foreach collection="ids" item="item" open="(" separator="," close=")">
                    #{item, jdbcType=BIGINT}
                </foreach>
            </if>
            <!-- 基础字段筛选（createTime和updateTime时间筛选） -->
            <if test="createTime != null">
                <if test="createTime[0] != '' and (createTime.size() lt 2 or createTime[1] == '')">
                    AND create_time >= #{createTime[0], jdbcType=TIMESTAMP}
                </if>
                <if test="createTime.size() >= 2 and createTime[0] == '' and createTime[1] != ''">
                    AND create_time &lt;= #{createTime[1], jdbcType=TIMESTAMP}
                </if>
                <if test="createTime.size() >= 2 and createTime[0] != '' and createTime[1] != ''">
                    AND create_time BETWEEN #{createTime[0], jdbcType=TIMESTAMP}
                    AND #{createTime[1], jdbcType=TIMESTAMP}
                </if>
            </if>
            <if test="updateTime != null">
                <if test="updateTime[0] != '' and (updateTime.size() lt 2 or updateTime[1] == '')">
                    AND update_time >= #{updateTime[0], jdbcType=TIMESTAMP}
                </if>
                <if test="updateTime.size() >= 2 and updateTime[0] == '' and updateTime[1] != ''">
                    AND update_time &lt;= #{updateTime[1], jdbcType=TIMESTAMP}
                </if>
                <if test="updateTime.size() >= 2 and updateTime[0] != '' and updateTime[1] != ''">
                    AND update_time BETWEEN #{updateTime[0], jdbcType=TIMESTAMP}
                    AND #{updateTime[1], jdbcType=TIMESTAMP}
                </if>
            </if>
            <!-- 业务字段筛选 -->
            <if test="username != null">
                AND username = #{username, jdbcType=VARCHAR}
            </if>
            <if test="password != null">
                AND password = #{password, jdbcType=VARCHAR}
            </if>
            <if test="realName != null">
                AND real_name = #{realName, jdbcType=VARCHAR}
            </if>
            <if test="sex != null">
                AND sex = #{sex, jdbcType=VARCHAR}
            </if>
            <if test="birthday != null">
                AND birthday = #{birthday, jdbcType=VARCHAR}
            </if>
            <if test="idNo != null">
                AND id_no = #{idNo, jdbcType=VARCHAR}
            </if>
            <if test="mobile != null">
                AND mobile = #{mobile, jdbcType=VARCHAR}
            </if>
            <if test="email != null">
                AND email = #{email, jdbcType=VARCHAR}
            </if>
            <if test="status != null">
                AND status = #{status, jdbcType=VARCHAR}
            </if>
            <!-- 过滤已删除的记录 -->
            AND (delete_flag = 0 OR delete_flag IS NULL)
        </where>
    </sql>

    <!-- 插入单条记录 -->
    <insert id="insert" parameterType="com.g2rain.basis.dao.po.PassportPo">
        INSERT INTO passport (
        <!-- 主键字段（自增主键不包含在插入语句中） -->
        id,
        <!-- 基础字段 -->
        create_time, update_time,
        <!-- 业务字段 -->
        username, password, real_name, sex, birthday, id_no, mobile, email, status,
        <!-- deleteFlag字段（如果存在） -->
        delete_flag,
        <!-- version字段（如果存在） -->
        version
        ) VALUES (
        <!-- 主键值（自增主键不包含） -->
        #{id, jdbcType=BIGINT},
        <!-- 基础字段值 -->
        #{createTime, jdbcType=TIMESTAMP}, #{updateTime, jdbcType=TIMESTAMP},
        <!-- 业务字段值 -->
        #{username, jdbcType=VARCHAR}, #{password, jdbcType=VARCHAR}, #{realName, jdbcType=VARCHAR},
        #{sex, jdbcType=VARCHAR}, #{birthday, jdbcType=VARCHAR}, #{idNo, jdbcType=VARCHAR}, #{mobile, jdbcType=VARCHAR},
        #{email, jdbcType=VARCHAR}, #{status, jdbcType=VARCHAR},
        <!-- deleteFlag字段值（如果存在，设置默认值为0） -->
        0,
        <!-- version字段值（如果存在，设置默认值为0） -->
        0
        )
    </insert>

    <!-- 批量插入记录 -->
    <insert id="insertMultiple" parameterType="java.util.List">
        INSERT INTO passport (
        <!-- 主键字段（自增主键不包含） -->
        id,
        <!-- 基础字段 -->
        create_time, update_time,
        <!-- 业务字段 -->
        username, password, real_name, sex, birthday, id_no, mobile, email, status,
        <!-- deleteFlag字段（如果存在） -->
        delete_flag,
        <!-- version字段（如果存在） -->
        version
        ) VALUES
        <foreach collection="list" item="item" separator=",">
            (
            <!-- 主键值（自增主键不包含） -->
            #{item.id, jdbcType=BIGINT},
            <!-- 基础字段值 -->
            #{item.createTime, jdbcType=TIMESTAMP}, #{item.updateTime, jdbcType=TIMESTAMP},
            <!-- 业务字段值 -->
            #{item.username, jdbcType=VARCHAR}, #{item.password, jdbcType=VARCHAR}, #{item.realName, jdbcType=VARCHAR},
            #{item.sex, jdbcType=VARCHAR}, #{item.birthday, jdbcType=VARCHAR}, #{item.idNo, jdbcType=VARCHAR},
            #{item.mobile, jdbcType=VARCHAR}, #{item.email, jdbcType=VARCHAR}, #{item.status, jdbcType=VARCHAR},
            <!-- deleteFlag字段值（如果存在，设置默认值为0） -->
            0,
            <!-- version字段值（如果存在，设置默认值为0） -->
            0
            )
        </foreach>
    </insert>

    <!-- 根据ID更新记录（包含基础字段和业务字段） -->
    <update id="update" parameterType="com.g2rain.basis.dao.po.PassportPo">
        UPDATE passport
        <set>
            real_name = #{realName, jdbcType=VARCHAR},
            sex = #{sex, jdbcType=VARCHAR},
            birthday = #{birthday, jdbcType=VARCHAR},
            id_no = #{idNo, jdbcType=VARCHAR},
            mobile = #{mobile, jdbcType=VARCHAR},
            email = #{email, jdbcType=VARCHAR},
            <!-- 基础字段更新（排除version，version单独处理） -->
            <if test="updateTime != null">
                update_time = #{updateTime, jdbcType=TIMESTAMP},
            </if>
            <!-- 业务字段更新 -->
            <if test="username != null">
                username = #{username, jdbcType=VARCHAR},
            </if>
            <if test="password != null">
                password = #{password, jdbcType=VARCHAR},
            </if>
            <if test="status != null">
                status = #{status, jdbcType=VARCHAR},
            </if>
            <!-- version字段更新（如果存在，版本号自增） -->
            version = version + 1
        </set>
        WHERE id = #{id, jdbcType=BIGINT}
    </update>

    <!-- 根据ID 局部更新记录（包含基础字段和业务字段） -->
    <update id="updateSelective" parameterType="com.g2rain.basis.dao.po.PassportPo">
        UPDATE passport
        <set>
            <!-- 基础字段更新（排除version，version单独处理） -->
            <if test="updateTime != null">
                update_time = #{updateTime, jdbcType=TIMESTAMP},
            </if>
            <!-- 业务字段更新 -->
            <if test="realName != null">
                real_name = #{realName, jdbcType=VARCHAR},
            </if>
            <if test="sex != null">
                sex = #{sex, jdbcType=VARCHAR},
            </if>
            <if test="birthday != null">
                birthday = #{birthday, jdbcType=VARCHAR},
            </if>
            <if test="idNo != null">
                id_no = #{idNo, jdbcType=VARCHAR},
            </if>
            <if test="mobile != null">
                mobile = #{mobile, jdbcType=VARCHAR},
            </if>
            <if test="email != null">
                email = #{email, jdbcType=VARCHAR},
            </if>
            <if test="username != null">
                username = #{username, jdbcType=VARCHAR},
            </if>
            <if test="password != null">
                password = #{password, jdbcType=VARCHAR},
            </if>
            <if test="status != null">
                status = #{status, jdbcType=VARCHAR},
            </if>
            <!-- version字段更新（如果存在，版本号自增） -->
            version = version + 1
        </set>
        WHERE id = #{id, jdbcType=BIGINT}
    </update>

    <!-- 根据ID和Version更新记录（乐观锁更新，包含基础字段和业务字段） -->
    <update id="updateByVersion" parameterType="com.g2rain.basis.dao.po.PassportPo">
        UPDATE passport
        <set>
            real_name = #{realName, jdbcType=VARCHAR},
            sex = #{sex, jdbcType=VARCHAR},
            birthday = #{birthday, jdbcType=VARCHAR},
            id_no = #{idNo, jdbcType=VARCHAR},
            mobile = #{mobile, jdbcType=VARCHAR},
            email = #{email, jdbcType=VARCHAR},
            <!-- 基础字段更新（排除version，version单独处理） -->
            <if test="updateTime != null">
                update_time = #{updateTime, jdbcType=TIMESTAMP},
            </if>
            <!-- 业务字段更新 -->
            <if test="username != null">
                username = #{username, jdbcType=VARCHAR},
            </if>
            <if test="password != null">
                password = #{password, jdbcType=VARCHAR},
            </if>
            <if test="status != null">
                status = #{status, jdbcType=VARCHAR},
            </if>
            <!-- version字段更新（乐观锁版本号自增） -->
            version = version + 1
        </set>
        WHERE id = #{id, jdbcType=BIGINT}
        AND version = #{version, jdbcType=INTEGER}
    </update>

    <!-- 根据ID删除记录（逻辑删除：将delete_flag设置为true） -->
    <update id="delete" parameterType="Long">
        UPDATE passport
        <set>
            delete_flag = 1, version = version + 1
        </set>
        WHERE id = #{id, jdbcType=BIGINT}
        <!-- 只删除未删除的记录 -->
        AND (delete_flag = 0 OR delete_flag IS NULL)
    </update>

    <!-- 根据ID查询记录（查询所有字段） -->
    <select id="selectById" parameterType="Long" resultMap="BaseResultMap">
        SELECT
        <!-- 主键字段 -->
        id,
        <!-- 基础字段 -->
        create_time, update_time,
        <!-- 业务字段 -->
        username, password, real_name, sex, birthday, id_no, mobile, email, status,
        <!-- deleteFlag字段（如果存在） -->
        delete_flag,
        <!-- version字段（如果存在） -->
        version
        FROM passport
        WHERE id = #{id, jdbcType=BIGINT}
        <!-- 过滤已删除的记录 -->
        AND (delete_flag = 0 OR delete_flag IS NULL)
    </select>

    <!-- 根据 SelectDto 条件查询列表 -->
    <select id="selectList" parameterType="com.g2rain.basis.dto.PassportSelectDto" resultMap="BaseResultMap">
        SELECT
        <!-- 主键字段 -->
        id,
        <!-- 基础字段 -->
        create_time, update_time,
        <!-- 业务字段 -->
        username, password, real_name, sex, birthday, id_no, mobile, email, status,
        <!-- deleteFlag字段（如果存在） -->
        delete_flag,
        <!-- version字段（如果存在） -->
        version
        FROM passport
        <include refid="commonWhereClause"/>
        <include refid="dynamicOrderBy"/>
    </select>

    <!-- 根据 SelectDto 条件 检查字段唯一性 -->
    <select id="checkFieldsUnique" parameterType="com.g2rain.basis.dto.PassportSelectDto" resultType="Long">
        SELECT count(1) TOTAL
        FROM passport
        <include refid="commonWhereClause"/>
    </select>
</mapper>
