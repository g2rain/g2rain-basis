<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.g2rain.basis.dao.PassportIdpBindingDao">
    <!-- 通用结果集映射（包含所有字段：主键+基础字段+业务字段） -->
    <resultMap id="BaseResultMap" type="com.g2rain.basis.dao.po.PassportIdpBindingPo">
        <!-- 主键字段 -->
        <id column="id" property="id" jdbcType="BIGINT"/>
        <!-- 基础字段（createTime、updateTime） -->
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
        <result column="update_time" property="updateTime" jdbcType="TIMESTAMP"/>
        <!-- 业务字段（其他自定义字段） -->
        <result column="passport_id" property="passportId" jdbcType="BIGINT"/>
        <result column="idp_type" property="idpType" jdbcType="VARCHAR"/>
        <result column="idp_subject" property="idpSubject" jdbcType="VARCHAR"/>
        <result column="corp_id" property="corpId" jdbcType="VARCHAR"/>
        <result column="idp_user_id" property="idpUserId" jdbcType="VARCHAR"/>
        <result column="bind_mode" property="bindMode" jdbcType="VARCHAR"/>
        <result column="raw_profile" property="rawProfile" jdbcType="LONGVARCHAR"/>
        <!-- deleteFlag字段（如果存在） -->
        <result column="delete_flag" property="deleteFlag" jdbcType="TINYINT"/>
        <!-- version字段（如果存在） -->
        <result column="version" property="version" jdbcType="INTEGER"/>
    </resultMap>

    <!-- 定义可复用排序方向片段 -->
    <sql id="directionClause">
        <choose>
            <when test="item.direction == 'DESC'">DESC</when>
            <otherwise>ASC</otherwise>
        </choose>
    </sql>

    <!-- 可复用的动态排序 SQL 片段 -->
    <sql id="dynamicOrderBy">
        <trim prefix="ORDER BY" suffixOverrides=",">
            <foreach collection="safeSorts" item="item" separator=",">
                <choose>
                    <when test="item.column == 'id'">
                        id
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'createTime'">
                        create_time
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'updateTime'">
                        update_time
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'passportId'">
                        passport_id
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'idpType'">
                        idp_type
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'idpSubject'">
                        idp_subject
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'corpId'">
                        corp_id
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'idpUserId'">
                        idp_user_id
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'bindMode'">
                        bind_mode
                        <include refid="directionClause"/>
                    </when>
                    <when test="item.column == 'rawProfile'">
                        raw_profile
                        <include refid="directionClause"/>
                    </when>
                </choose>
            </foreach>
        </trim>
    </sql>

    <!-- 插入单条记录 -->
    <insert id="insert" parameterType="com.g2rain.basis.dao.po.PassportIdpBindingPo">
        INSERT INTO passport_idp_binding (
        <!-- 主键字段（自增主键不包含在插入语句中） -->
        id,
        <!-- 基础字段 -->
        create_time, update_time,
        <!-- 业务字段 -->
        passport_id, idp_type, idp_subject, corp_id, idp_user_id, bind_mode, raw_profile,
        <!-- deleteFlag字段（如果存在） -->
        delete_flag,
        <!-- version字段（如果存在） -->
        version
        ) VALUES (
        <!-- 主键值（自增主键不包含） -->
        #{id, jdbcType=BIGINT},
        <!-- 基础字段值 -->
        #{createTime, jdbcType=TIMESTAMP}, #{updateTime, jdbcType=TIMESTAMP},
        <!-- 业务字段值 -->
        #{passportId, jdbcType=BIGINT}, #{idpType, jdbcType=VARCHAR}, #{idpSubject, jdbcType=VARCHAR}, #{corpId, jdbcType=VARCHAR}, #{idpUserId, jdbcType=VARCHAR}, #{bindMode, jdbcType=VARCHAR}, #{rawProfile, jdbcType=LONGVARCHAR},
        <!-- deleteFlag字段值（如果存在，设置默认值为0） -->
        0,
        <!-- version字段值（如果存在，设置默认值为0） -->
        0
        )
    </insert>

    <!-- 批量插入记录 -->
    <insert id="insertMultiple" parameterType="java.util.List">
        INSERT INTO passport_idp_binding (
        <!-- 主键字段（自增主键不包含） -->
        id,
        <!-- 基础字段 -->
        create_time, update_time,
        <!-- 业务字段 -->
        passport_id, idp_type, idp_subject, corp_id, idp_user_id, bind_mode, raw_profile,
        <!-- deleteFlag字段（如果存在） -->
        delete_flag,
        <!-- version字段（如果存在） -->
        version
        ) VALUES
        <foreach collection="list" item="item" separator=",">
            (
            <!-- 主键值（自增主键不包含） -->
            #{item.id, jdbcType=BIGINT},
            <!-- 基础字段值 -->
            #{item.createTime, jdbcType=TIMESTAMP}, #{item.updateTime, jdbcType=TIMESTAMP},
            <!-- 业务字段值 -->
            #{item.passportId, jdbcType=BIGINT}, #{item.idpType, jdbcType=VARCHAR}, #{item.idpSubject, jdbcType=VARCHAR}, #{item.corpId, jdbcType=VARCHAR}, #{item.idpUserId, jdbcType=VARCHAR}, #{item.bindMode, jdbcType=VARCHAR}, #{item.rawProfile, jdbcType=LONGVARCHAR},
            <!-- deleteFlag字段值（如果存在，设置默认值为0） -->
            0,
            <!-- version字段值（如果存在，设置默认值为0） -->
            0
            )
        </foreach>
    </insert>

    <!-- 根据ID更新记录（包含基础字段和业务字段） -->
    <update id="update" parameterType="com.g2rain.basis.dao.po.PassportIdpBindingPo">
        UPDATE passport_idp_binding
        <set>
            <!-- 基础字段更新（排除version，version单独处理） -->
            <if test="updateTime != null">
                update_time = #{updateTime, jdbcType=TIMESTAMP},
            </if>
            <!-- 业务字段更新 -->
            <if test="passportId != null">
                passport_id = #{passportId, jdbcType=BIGINT},
            </if>
            <if test="idpType != null">
                idp_type = #{idpType, jdbcType=VARCHAR},
            </if>
            <if test="idpSubject != null">
                idp_subject = #{idpSubject, jdbcType=VARCHAR},
            </if>
            <if test="corpId != null">
                corp_id = #{corpId, jdbcType=VARCHAR},
            </if>
            <if test="idpUserId != null">
                idp_user_id = #{idpUserId, jdbcType=VARCHAR},
            </if>
            <if test="bindMode != null">
                bind_mode = #{bindMode, jdbcType=VARCHAR},
            </if>
            <if test="rawProfile != null">
                raw_profile = #{rawProfile, jdbcType=LONGVARCHAR},
            </if>
            <!-- version字段更新（如果存在，版本号自增） -->
            version = version + 1
        </set>
        WHERE id = #{id, jdbcType=BIGINT}
    </update>

    <!-- 根据ID和Version更新记录（乐观锁更新，包含基础字段和业务字段） -->
    <update id="updateByVersion" parameterType="com.g2rain.basis.dao.po.PassportIdpBindingPo">
        UPDATE passport_idp_binding
        <set>
            <!-- 基础字段更新（排除version，version单独处理） -->
            <if test="updateTime != null">
                update_time = #{updateTime, jdbcType=TIMESTAMP},
            </if>
            <!-- 业务字段更新 -->
            <if test="passportId != null">
                passport_id = #{passportId, jdbcType=BIGINT},
            </if>
            <if test="idpType != null">
                idp_type = #{idpType, jdbcType=VARCHAR},
            </if>
            <if test="idpSubject != null">
                idp_subject = #{idpSubject, jdbcType=VARCHAR},
            </if>
            <if test="corpId != null">
                corp_id = #{corpId, jdbcType=VARCHAR},
            </if>
            <if test="idpUserId != null">
                idp_user_id = #{idpUserId, jdbcType=VARCHAR},
            </if>
            <if test="bindMode != null">
                bind_mode = #{bindMode, jdbcType=VARCHAR},
            </if>
            <if test="rawProfile != null">
                raw_profile = #{rawProfile, jdbcType=LONGVARCHAR},
            </if>
            <!-- version字段更新（乐观锁版本号自增） -->
            version = version + 1
        </set>
        WHERE id = #{id, jdbcType=BIGINT}
        AND version = #{version, jdbcType=INTEGER}
    </update>

    <!-- 根据ID删除记录（逻辑删除：将delete_flag设置为true） -->
    <update id="delete" parameterType="Long">
        UPDATE passport_idp_binding
        <set>
            delete_flag = 1, version = version + 1
        </set>
        WHERE id = #{id, jdbcType=BIGINT}
        <!-- 只删除未删除的记录 -->
        AND (delete_flag = 0 OR delete_flag IS NULL)
    </update>

    <!-- 根据ID查询记录（查询所有字段） -->
    <select id="selectById" parameterType="Long" resultMap="BaseResultMap">
        SELECT
        <!-- 主键字段 -->
        id,
        <!-- 基础字段 -->
        create_time, update_time,
        <!-- 业务字段 -->
        passport_id, idp_type, idp_subject, corp_id, idp_user_id, bind_mode, raw_profile,
        <!-- deleteFlag字段（如果存在） -->
        delete_flag,
        <!-- version字段（如果存在） -->
        version
        FROM passport_idp_binding
        WHERE id = #{id, jdbcType=BIGINT}
        <!-- 过滤已删除的记录 -->
        AND (delete_flag = 0 OR delete_flag IS NULL)
    </select>

    <!-- 根据SelectDto条件查询列表 -->
    <select id="selectList" parameterType="com.g2rain.basis.dto.PassportIdpBindingSelectDto" resultMap="BaseResultMap">
        SELECT
        <!-- 主键字段 -->
        id,
        <!-- 基础字段 -->
        create_time, update_time,
        <!-- 业务字段 -->
        passport_id, idp_type, idp_subject, corp_id, idp_user_id, bind_mode, raw_profile,
        <!-- deleteFlag字段（如果存在） -->
        delete_flag,
        <!-- version字段（如果存在） -->
        version
        FROM passport_idp_binding
        <where>
            <!-- 主键筛选 -->
            <if test="id != null">
                AND id = #{id, jdbcType=BIGINT}
            </if>
            <if test="ids != null and ids.size() > 0">
                AND id IN
                <foreach collection="ids" item="item" open="(" separator="," close=")">
                    #{item, jdbcType=BIGINT}
                </foreach>
            </if>
            <!-- 基础字段筛选（createTime和updateTime时间筛选） -->
            <if test="createTime != null">
                <if test="createTime[0] != '' and (createTime.size() lt 2 or createTime[1] == '')">
                    AND create_time >= #{createTime[0], jdbcType=TIMESTAMP}
                </if>
                <if test="createTime.size() >= 2 and createTime[0] == '' and createTime[1] != ''">
                    AND create_time &lt;= #{createTime[1], jdbcType=TIMESTAMP}
                </if>
                <if test="createTime.size() >= 2 and createTime[0] != '' and createTime[1] != ''">
                    AND create_time BETWEEN #{createTime[0], jdbcType=TIMESTAMP}
                    AND #{createTime[1], jdbcType=TIMESTAMP}
                </if>
            </if>
            <if test="updateTime != null">
                <if test="updateTime[0] != '' and (updateTime.size() lt 2 or updateTime[1] == '')">
                    AND update_time >= #{updateTime[0], jdbcType=TIMESTAMP}
                </if>
                <if test="updateTime.size() >= 2 and updateTime[0] == '' and updateTime[1] != ''">
                    AND update_time &lt;= #{updateTime[1], jdbcType=TIMESTAMP}
                </if>
                <if test="updateTime.size() >= 2 and updateTime[0] != '' and updateTime[1] != ''">
                    AND update_time BETWEEN #{updateTime[0], jdbcType=TIMESTAMP}
                    AND #{updateTime[1], jdbcType=TIMESTAMP}
                </if>
            </if>
            <!-- 业务字段筛选 -->
            <if test="passportId != null">
                AND passport_id = #{passportId, jdbcType=BIGINT}
            </if>
            <if test="idpType != null">
                AND idp_type = #{idpType, jdbcType=VARCHAR}
            </if>
            <if test="idpSubject != null">
                AND idp_subject = #{idpSubject, jdbcType=VARCHAR}
            </if>
            <if test="corpId != null">
                AND corp_id = #{corpId, jdbcType=VARCHAR}
            </if>
            <if test="idpUserId != null">
                AND idp_user_id = #{idpUserId, jdbcType=VARCHAR}
            </if>
            <if test="bindMode != null">
                AND bind_mode = #{bindMode, jdbcType=VARCHAR}
            </if>
            <if test="rawProfile != null">
                AND raw_profile = #{rawProfile, jdbcType=LONGVARCHAR}
            </if>
            <!-- 过滤已删除的记录 -->
            AND (delete_flag = 0 OR delete_flag IS NULL)
        </where>
        <include refid="dynamicOrderBy"/>
    </select>
</mapper>
